SysPoint? FindImageTemplate(RECT searchArea, string base64Image, double threshold = 0.8, double timeout = 3) {
    using var needle = LoadImageFromBase64(base64Image);
    if (needle.Empty()) return null;

    var sw = Stopwatch.StartNew();
    do {
        using var bmp = CaptureScreen.Image(searchArea);
        using var ms = new MemoryStream();
        bmp.Save(ms, ImageFormat.Png);
        ms.Position = 0;
        using var haystack = Mat.FromImageData(ms.ToArray());

        using var result = new Mat();
        Cv2.MatchTemplate(haystack, needle, result, TemplateMatchModes.CCoeffNormed);

        double minVal, maxVal;
        OpenCvSharp.Point minLoc, maxLoc;
        Cv2.MinMaxLoc(result, out minVal, out maxVal, out minLoc, out maxLoc);

        if (maxVal >= threshold) {
            return new SysPoint(
                searchArea.left + maxLoc.X + needle.Width / 2,
                searchArea.top + maxLoc.Y + needle.Height / 2
            );
        }

        if (timeout > 0) 50.ms();
    } while (sw.Elapsed.TotalSeconds < timeout);

    return null;
}


//Template Matching — для мелких иконок (кнопки, значки)
SysPoint? FindImageOrbSimple(RECT searchArea, string base64Image, double timeout = 3) {
    using var needle = LoadImageFromBase64(base64Image);
    if (needle.Empty()) return null;

    var orb = ORB.Create(nFeatures: 2000, fastThreshold: 10); // мягче порог FAST
    var bf = new BFMatcher(NormTypes.Hamming);

    KeyPoint[] needleKp;
    Mat needleDesc = new();
    orb.DetectAndCompute(needle, null, out needleKp, needleDesc);
    if (needleKp.Length < 2) return null;

    // Автоматически задаём minGoodMatches как 30% от точек образца, но не меньше 4
    int minGood = Math.Max(4, (int)(needleKp.Length * 0.3));

    var sw = Stopwatch.StartNew();
    do {
        using var bmp = CaptureScreen.Image(searchArea);
        using var ms = new MemoryStream();
        bmp.Save(ms, ImageFormat.Png);
        ms.Position = 0;
        using var haystack = Mat.FromImageData(ms.ToArray());

        KeyPoint[] haystackKp;
        Mat haystackDesc = new();
        orb.DetectAndCompute(haystack, null, out haystackKp, haystackDesc);

        var matches = bf.KnnMatch(needleDesc, haystackDesc, k: 2);
        var good = matches.Where(m => m.Length == 2 && m[0].Distance < 0.8 * m[1].Distance).ToArray();

        if (good.Length >= minGood) {
            // Среднее смещение по хорошим совпадениям (без гомографии)
            int sumX = 0, sumY = 0;
            foreach (var m in good) {
                var pt = haystackKp[m[0].TrainIdx].Pt;
                sumX += (int)pt.X;
                sumY += (int)pt.Y;
            }
            return new SysPoint(
                searchArea.left + sumX / good.Length,
                searchArea.top + sumY / good.Length
            );
        }

        if (timeout > 0) 50.ms();
    } while (sw.Elapsed.TotalSeconds < timeout);

    return null;
}


 
/// <summary>
/// Надёжный поиск изображения через OpenCV (ORB + гомография).
/// Устойчив к сглаживанию, небольшим поворотам и перерисовке.
/// </summary>
/// <param name="searchArea">Прямоугольник области поиска (например, w.ClientRect, screen.primary.Rect).</param>
/// <param name="base64Image">Образец в base64.</param>
/// <param name="minGoodMatches">Минимальное число хороших совпадений (по умолчанию 10).</param>
/// <param name="timeout">Время ожидания в секундах (0 – без ожидания).</param>
/// <returns>Центр найденного изображения или null.</returns>
SysPoint? FindImageRobust(RECT searchArea, string base64Image, int minGoodMatches = 10, double timeout = 3) {
    using var needle = LoadImageFromBase64(base64Image);
    if (needle.Empty()) return null;

    var orb = ORB.Create(5000);
    var bf = new BFMatcher(NormTypes.Hamming);
    
    KeyPoint[] needleKp;
    Mat needleDesc = new();
    orb.DetectAndCompute(needle, null, out needleKp, needleDesc);
    if (needleKp.Length < 4) { print.it("⚠️ Мало ключевых точек в образце"); return null; }

    var sw = Stopwatch.StartNew();
    do {
        // Захват области экрана (документированный способ)
        using var bmp = CaptureScreen.Image(searchArea);
        // Конвертация Bitmap -> Mat
        using var ms = new MemoryStream();
        bmp.Save(ms, ImageFormat.Png);
        ms.Position = 0;
        using var haystack = Mat.FromImageData(ms.ToArray());

        KeyPoint[] haystackKp;
        Mat haystackDesc = new();
        orb.DetectAndCompute(haystack, null, out haystackKp, haystackDesc);

        var matches = bf.KnnMatch(needleDesc, haystackDesc, k: 2);
        var good = matches.Where(m => m.Length == 2 && m[0].Distance < 0.75 * m[1].Distance).ToArray();

        if (good.Length >= minGoodMatches && good.Length >= 4) {
            var srcPts = good.Select(m => needleKp[m[0].QueryIdx].Pt).ToArray();
            var dstPts = good.Select(m => haystackKp[m[0].TrainIdx].Pt).ToArray();

            var homography = Cv2.FindHomography(
                InputArray.Create(srcPts), InputArray.Create(dstPts),
                HomographyMethods.Ransac, ransacReprojThreshold: 3
            );
            if (homography != null && !homography.Empty()) {
                Point2f[] centerPoint = { new Point2f(needle.Width / 2f, needle.Height / 2f) };
                var transformed = Cv2.PerspectiveTransform(centerPoint, homography);
                // Координаты относительно левого верхнего угла searchArea
                return new SysPoint(
                    searchArea.left + (int)transformed[0].X,
                    searchArea.top + (int)transformed[0].Y
                );
            }
        }
        if (timeout > 0) 50.ms();
    } while (sw.Elapsed.TotalSeconds < timeout);

    return null;
}
