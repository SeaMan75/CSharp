/// <summary>
/// Распознаёт текст в заданной области экрана с помощью PaddleOCR.
/// </summary>
/// <param name="searchArea">Область экрана (например, w.ClientRect).</param>
/// <param name="language">Язык модели: "ch", "en", "ch_en" и т.д. По умолчанию "en".</param>
/// <returns>Распознанный текст.</returns>
string ReadTextPaddle(RECT searchArea, string language = "en") {
    // Захват скриншота
    using var bmp = CaptureScreen.Image(searchArea);
    // Конвертируем в формат, понятный PaddleOCR (можно использовать Mat или Bitmap)
    using var ms = new MemoryStream();
    bmp.Save(ms, System.Drawing.Imaging.ImageFormat.Png);
    ms.Position = 0;
    
    // Загрузка модели (при первом вызове может скачать)
    var model = PaddleOCRLocalModel.Create(language, detectionModelVersion: "PP-OCRv4");
    
    // Создание движка
    using var engine = new PaddleOcrEngine(model);
    
    // Распознавание
    var results = engine.Run(ms);
    
    // Сборка текста из всех найденных блоков
    var sb = new StringBuilder();
    foreach (var block in results) {
        sb.AppendLine(block.Text);
    }
    return sb.ToString().Trim();
}
