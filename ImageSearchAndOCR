// Загрузка из base64
Mat LoadImageFromBase64(string base64) {
    if (base64.StartsWith("image:")) base64 = base64[6..];
    byte[] bytes = Convert.FromBase64String(base64);
    return Mat.FromImageData(bytes);
}
